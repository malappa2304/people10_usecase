# =============================================================================
# .env.example
#
# Template for local development env vars. Copy to .env.local (gitignored)
# and fill in real values for your dev workspace. Production CI/CD does NOT
# use this file — it would federate via OIDC (described in design doc §8.1).
# =============================================================================

# ---- Azure subscription / tenant -------------------------------------------
# Used by `az login` and the local terraform plan against your dev RG.
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000

# ---- Databricks workspace --------------------------------------------------
# Required by `databricks bundle validate / deploy` — `make smoke` uses these.
DATABRICKS_HOST=https://adb-dev.azuredatabricks.net
# Token only for local dev. CI uses OIDC + AAD token from `az`.
# DATABRICKS_TOKEN=dapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- Storage account -------------------------------------------------------
# Used in DLT pipeline configuration when running standalone in a workspace.
LAKE_ACCOUNT=chandanlakedev

# ---- Event Hubs (streaming source) ----------------------------------------
EH_BOOTSTRAP=chandan-eventhubs-dev.servicebus.windows.net:9093
EH_TOPIC=cnc-telemetry

# ---- Terraform backend (only if you're running tf-plan locally) -----------
# Mirrors the values CI passes via -backend-config flags.
TFSTATE_RG=rg-tfstate
TFSTATE_STORAGE_ACCOUNT=tfstatechandandev

# ---- Notes -----------------------------------------------------------------
# Never commit .env.local. It's in .gitignore. If you somehow do, run
#   git rm --cached .env.local && git commit
# and rotate any secrets that were inside.
