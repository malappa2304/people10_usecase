# =============================================================================
# CODEOWNERS — required reviewers per area.
#
# Order matters; the LAST matching pattern wins.
# Branch protection on develop/uat/main enforces these as required reviewers.
# =============================================================================

# Default — data-platform-team owns everything not covered below.
*                                       @data-platform-team

# Architecture, design, presentation
/docs/                                  @data-platform-lead

# Infra (Terraform + Bicep) — IaC owners + security review
/poc/infrastructure/                    @data-platform-lead @cloud-platform-team
/poc/infrastructure/networking.tf       @cloud-platform-team @security-team

# CI/CD pipelines — devops owners + security review
/.github/                               @devops-team @security-team
/.github/workflows/cd-*.yml             @devops-team @data-platform-lead @security-team

# Databricks production library — must keep API stable
/poc/databricks/lib/                    @data-platform-lead

# DQ rules + DLT pipelines — quality team co-reviews
/poc/databricks/notebooks/03_dlt_*.py   @data-platform-team @quality-engineering
/poc/databricks/notebooks/05_dq_*.py    @data-platform-team @quality-engineering
/poc/config/dq_rules_seed.sql           @data-platform-team @quality-engineering

# Reconciliation framework — migration owners
/poc/databricks/lib/reconciliation.py   @data-platform-lead @migration-pmo
/poc/config/reconciliation_tolerance.yaml @data-platform-lead @migration-pmo

# Synapse DDL touches the BI semantic layer — analytics review required
/poc/synapse/                           @data-platform-team @analytics-team

# QA artefacts
/qa/                                    @qa-team @data-platform-lead
