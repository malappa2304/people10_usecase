{
  "name": "ls_adls_bronze",
  "properties": {
    "description": "ADLS Gen2 Bronze container. CMK from Key Vault, Private Endpoint only.",
    "type": "AzureBlobFS",
    "typeProperties": {
      "url": "https://chandanlake.dfs.core.windows.net",
      "accountKey": {
        "type": "AzureKeyVaultSecret",
        "store": { "referenceName": "ls_keyvault", "type": "LinkedServiceReference" },
        "secretName": "adls-bronze-account-key"
      }
    },
    "connectVia": { "referenceName": "ir_managed_vnet", "type": "IntegrationRuntimeReference" }
  }
}
