{
  "name": "trg_daily_master",
  "properties": {
    "description": "Daily 02:00 IST schedule trigger for the master orchestrator. Picks up the day's batch window after SAP closes its 01:30 IST cycle.",
    "type": "ScheduleTrigger",
    "typeProperties": {
      "recurrence": {
        "frequency": "Day",
        "interval": 1,
        "startTime": "2025-04-01T02:00:00",
        "timeZone": "India Standard Time",
        "schedule": {
          "hours": [2],
          "minutes": [0]
        }
      }
    },
    "pipelines": [
      {
        "pipelineReference": { "referenceName": "pl_master_orchestrator", "type": "PipelineReference" },
        "parameters": {
          "runDate": "@formatDateTime(trigger().scheduledTime, 'yyyy-MM-dd')"
        }
      }
    ]
  }
}
