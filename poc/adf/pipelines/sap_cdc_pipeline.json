{
  "name": "pl_sap_cdc",
  "properties": {
    "description": "SAP S/4HANA CDC → Bronze. Uses ADF SAP CDC connector via SHIR. Delta extraction is connector-managed; we land Parquet partitioned by source_system/ingest_date.",
    "parameters": {
      "sourceId":         { "type": "Int" },
      "entity":           { "type": "String" },
      "targetBronzePath": { "type": "String" },
      "runDate":          { "type": "String" }
    },
    "activities": [
      {
        "name": "Copy_SAP_CDC_To_Bronze",
        "type": "Copy",
        "policy": { "timeout": "0.04:00:00", "retry": 2, "retryIntervalInSeconds": 120 },
        "typeProperties": {
          "source": {
            "type": "SapCdcSource",
            "subscriberProcess": {
              "value": "@concat('CHANDAN_', pipeline().parameters.entity)",
              "type": "Expression"
            },
            "selection": [
              { "fieldName": "MANDT", "isLow": "100" }
            ],
            "additionalColumns": [
              { "name": "ingest_run_id", "value": { "value": "@pipeline().RunId", "type": "Expression" } },
              { "name": "ingest_ts_utc", "value": { "value": "@utcnow()", "type": "Expression" } }
            ]
          },
          "sink": {
            "type": "ParquetSink",
            "storeSettings": {
              "type": "AzureBlobFSWriteSettings",
              "copyBehavior": "PreserveHierarchy"
            }
          },
          "enableStaging": true,
          "stagingSettings": {
            "linkedServiceName": { "referenceName": "ls_adls_staging", "type": "LinkedServiceReference" },
            "path": "staging/sap_cdc"
          },
          "parallelCopies": 8,
          "dataIntegrationUnits": 32
        },
        "inputs": [{
          "referenceName": "ds_sap_cdc_table",
          "type": "DatasetReference",
          "parameters": { "tableName": "@pipeline().parameters.entity" }
        }],
        "outputs": [{
          "referenceName": "ds_adls_bronze",
          "type": "DatasetReference",
          "parameters": {
            "path": {
              "value": "@concat(pipeline().parameters.targetBronzePath, '/ingest_date=', pipeline().parameters.runDate)",
              "type": "Expression"
            },
            "fileName": "@concat(pipeline().parameters.entity, '.parquet')"
          }
        }]
      }
    ],
    "annotations": ["sap-cdc"]
  }
}
